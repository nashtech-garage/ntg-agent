@page "/inner-agents/new"
@page "/inner-agents/{id:guid}"
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using NTG.Agent.Common.Dtos.Agents
@using NTG.Agent.Admin.Client.Components
@using System.Net.Http
@inject AgentClient AgentClient
@inject NavigationManager Navigation
@inject ILogger<InnerAgentDetails> Logger

<PageTitle>@(isNew ? "Create Inner Agent" : "Inner Agent Details")</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/inner-agents" class="text-decoration-none">Inner Agents</a></li>
                    <li class="breadcrumb-item active" aria-current="page">
                        @(isNew ? "Create Inner Agent" : innerAgentDetail.Name)
                    </li>
                </ol>
            </nav>

            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3"
                     style="width: 40px; height: 40px;">
                    <i class="bi @(isNew ? "bi-plus-circle" : "bi-gear") text-white" style="font-size: 1.2rem;"></i>
                </div>
                <div>
                    <h1 class="h3 mb-0">@(isNew ? "Create Inner Agent" : innerAgentDetail.Name)</h1>
                    <small class="text-muted">Define a focused agent that can be called as a tool.</small>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @errorMessage
                    <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                    <div class="text-center">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Loading inner agent...</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12 col-lg-10 col-xl-8">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <EditForm Model="@innerAgentDetail" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />

                            <div class="mb-4">
                                <label for="name" class="form-label fw-semibold">
                                    <i class="bi bi-robot me-2 text-primary"></i>
                                    Agent Name <span class="text-danger">*</span>
                                </label>
                                <InputText id="name" class="form-control form-control-lg" @bind-Value="innerAgentDetail.Name"
                                           placeholder="Enter agent name" disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => innerAgentDetail.Name)" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label for="description" class="form-label fw-semibold">
                                    <i class="bi bi-info-square me-2 text-primary"></i>
                                    Description <span class="text-muted">(Optional)</span>
                                </label>
                                <InputTextArea id="description" class="form-control" rows="3" @bind-Value="innerAgentDetail.Description"
                                               placeholder="Enter a brief description of the inner agent..." disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => innerAgentDetail.Description)" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label for="instructions" class="form-label fw-semibold">
                                    <i class="bi bi-card-text me-2 text-primary"></i>
                                    System Prompt / Role <span class="text-muted">(Optional)</span>
                                </label>
                                <InputTextArea id="instructions" class="form-control" rows="6" @bind-Value="innerAgentDetail.Instructions"
                                               placeholder="Enter detailed instructions for the inner agent..." disabled="@isSubmitting" />
                            </div>

                            <hr class="my-4" />

                            <h5 class="mb-3">
                                <i class="bi bi-gear-fill me-2 text-primary"></i>
                                Provider Configuration
                            </h5>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="providerName" class="form-label fw-semibold">
                                        Provider Name <span class="text-muted">(Optional)</span>
                                    </label>
                                    <select id="providerName" class="form-select" @bind="innerAgentDetail.ProviderName" disabled="@isSubmitting">
                                        <option value="">Select a provider...</option>
                                        <option value="GitHubModel">GitHub Models</option>
                                        <option value="AzureOpenAI">Azure Open AI</option>
                                        <option value="GoogleGemini">Google Gemini</option>
                                        <option value="OpenAI">OpenAI</option>
                                        <option value="Anthropic">Anthropic</option>
                                    </select>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="providerModelName" class="form-label fw-semibold">
                                        Model Name <span class="text-muted">(Optional)</span>
                                    </label>
                                    <InputText id="providerModelName" class="form-control" @bind-Value="innerAgentDetail.ProviderModelName"
                                               placeholder="e.g., gpt-4o-mini, claude-3-haiku" disabled="@isSubmitting" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="providerEndpoint" class="form-label fw-semibold">
                                    Provider Endpoint <span class="text-muted">(Optional)</span>
                                </label>
                                <InputText id="providerEndpoint" class="form-control" @bind-Value="innerAgentDetail.ProviderEndpoint"
                                           placeholder="https://api.openai.com/v1" disabled="@isSubmitting" />
                            </div>

                            <div class="mb-4">
                                <label for="providerApiKey" class="form-label fw-semibold">
                                    API Key <span class="text-muted">(Optional)</span>
                                </label>
                                <div class="input-group">
                                    <InputText id="providerApiKey" type="@(showApiKey ? "text" : "password")" class="form-control" @bind-Value="innerAgentDetail.ProviderApiKey"
                                               placeholder="Enter API key" disabled="@isSubmitting" />
                                    <button class="btn btn-outline-secondary" type="button" @onclick="() => showApiKey = !showApiKey"
                                            title="@(showApiKey ? "Hide API key" : "Show API key")" disabled="@isSubmitting">
                                        <i class="bi @(showApiKey ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2">
                                <button type="button" class="btn btn-outline-secondary" @onclick="NavigateBack" disabled="@isSubmitting">
                                    <i class="bi bi-x-circle me-2"></i>
                                    Cancel
                                </button>
                                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-circle me-2"></i>
                                        <span>@(isNew ? "Create Inner Agent" : "Save Changes")</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="mb-3">
                            <i class="bi bi-wrench me-2 text-primary"></i>
                            MCP Skills Binding
                        </h5>
                        @if (isNew)
                        {
                            <div class="alert alert-info d-flex align-items-center" role="alert">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                <div>Save the inner agent first to configure MCP skills.</div>
                            </div>
                        }
                        else
                        {
                            <InnerAgentToolManagementTab InnerAgent="innerAgentDetail" />
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private InnerAgentDetail innerAgentDetail = new();
    private bool isSubmitting = false;
    private bool isLoading = false;
    private bool showApiKey = false;
    private string? errorMessage;
    private bool isNew => !Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            try
            {
                isLoading = true;
                var existing = await AgentClient.GetInnerAgentAsync(Id.Value);
                if (existing != null)
                {
                    innerAgentDetail = existing;
                }
                else
                {
                    errorMessage = "Inner agent not found.";
                }
            }
            catch (HttpRequestException ex)
            {
                Logger.LogError(ex, "Failed to load inner agent.");
                errorMessage = "Failed to load inner agent.";
            }
            finally
            {
                isLoading = false;
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = null;

            if (isNew)
            {
                var createdId = await AgentClient.CreateInnerAgentAsync(innerAgentDetail);
                Navigation.NavigateTo($"/inner-agents/{createdId}");
            }
            else
            {
                await AgentClient.UpdateInnerAgentAsync(innerAgentDetail);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save inner agent.");
            errorMessage = "Failed to save inner agent.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/inner-agents");
    }
}
