@page "/inner-agents"
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using NTG.Agent.Common.Dtos.Agents
@inject AgentClient AgentClient

<PageTitle>Agent as a Tool Management</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="mb-0">
                    <i class="bi bi-diagram-3 me-2"></i>
                    Agent as a Tool Management
                </h1>
                <a href="/inner-agents/new" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>
                    Create Inner Agent
                </a>
            </div>
        </div>
    </div>

    @if (innerAgents == null)
    {
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                    <div class="text-center">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Loading inner agents...</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (innerAgents.Count == 0)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info d-flex align-items-center" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <div>No inner agents found. Create your first inner agent to get started!</div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var agent in innerAgents)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0" style="border-left: 4px solid #1b6ec2 !important;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0 text-truncate" title="@agent.Name">
                                    <i class="bi bi-robot me-2 text-primary"></i>
                                    @agent.Name
                                </h5>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(agent.Description))
                            {
                                <p class="text-muted small mb-2">@agent.Description</p>
                            }

                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-cpu-fill me-2 text-info"></i>
                                <div>
                                    <small class="text-muted d-block">Model</small>
                                    <span class="fw-medium">@agent.ProviderModelName</span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center">
                                <i class="bi bi-clock me-2 text-success"></i>
                                <div>
                                    <small class="text-muted d-block">Updated</small>
                                    <span class="fw-medium">@agent.UpdatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 pt-0">
                            <a href="@($"/inner-agents/{agent.Id}")" class="btn btn-primary w-100">
                                <i class="bi bi-gear me-2"></i>
                                Manage Inner Agent
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IList<InnerAgentListItem>? innerAgents;

    protected override async Task OnInitializedAsync()
    {
        innerAgents = await AgentClient.GetInnerAgentsAsync();
    }
}
