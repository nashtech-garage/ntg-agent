@page "/"
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using NTG.Agent.Common.Dtos.Agents
@using NTG.Agent.Admin.Client.Components
@inject AgentClient AgentClient
@inject NavigationManager Navigation

<PageTitle>Home</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="mb-0">
                    <i class="bi bi-house-door-fill me-2"></i>
                    Agent Dashboard
                </h1>
                <div class="d-flex gap-2">
                    <a href="/inner-agents/new" class="btn btn-outline-primary">
                        <i class="bi bi-tools me-2"></i>
                        Create Inner Agent
                    </a>
                    <a href="/agents/new" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>
                        Create New Agent
                    </a>
                </div>
            </div>

            <ul class="nav nav-tabs mb-4">
                <li class="nav-item">
                    <button class="nav-link @(filterKind == null ? "active" : "")"
                            @onclick="() => SetFilter(null)">
                        <i class="bi bi-grid me-1"></i> All
                        @if (allAgents != null)
                        {
                            <span class="badge bg-secondary ms-1">@allAgents.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(filterKind == AgentKind.Outer ? "active" : "")"
                            @onclick="() => SetFilter(AgentKind.Outer)">
                        <i class="bi bi-people-fill me-1"></i> Outer Agents
                        @if (allAgents != null)
                        {
                            <span class="badge bg-primary ms-1">@allAgents.Count(a => a.AgentKind == AgentKind.Outer)</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(filterKind == AgentKind.Inner ? "active" : "")"
                            @onclick="() => SetFilter(AgentKind.Inner)">
                        <i class="bi bi-tools me-1"></i> Inner Agents
                        @if (allAgents != null)
                        {
                            <span class="badge bg-success ms-1">@allAgents.Count(a => a.AgentKind == AgentKind.Inner)</span>
                        }
                    </button>
                </li>
            </ul>
        </div>
    </div>

    @if (allAgents == null)
    {
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                    <div class="text-center">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Loading agents...</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (displayedAgents.Count == 0)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info d-flex align-items-center" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <div>
                        @if (filterKind == null)
                        {
                            <span>No agents found. Create your first agent to get started!</span>
                        }
                        else if (filterKind == AgentKind.Outer)
                        {
                            <span>No outer agents found. <a href="/agents/new" class="alert-link">Create an outer agent</a> to get started.</span>
                        }
                        else
                        {
                            <span>No inner agents found. <a href="/inner-agents/new" class="alert-link">Create an inner agent</a> to get started.</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var agent in displayedAgents)
            {
                var isInnerKind = agent.AgentKind == AgentKind.Inner;
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0" style="border-left: 4px solid @(isInnerKind ? "#198754" : "#1b6ec2") !important;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0 text-truncate" title="@agent.Name">
                                    <i class="bi @(isInnerKind ? "bi-tools" : "bi-robot") me-2 @(isInnerKind ? "text-success" : "text-primary")"></i>
                                    @agent.Name
                                </h5>
                                <small class="text-muted">
                                    ID: @agent.Id.ToString()[..8]...
                                </small>
                            </div>

                            <div class="mb-2">
                                <span class="badge @(isInnerKind ? "bg-success-subtle text-success" : "bg-info-subtle text-info")">
                                    @(isInnerKind ? "Inner Agent" : "Outer Agent")
                                </span>
                            </div>

                            <div class="mb-3">
                                <div class="row g-2">
                                    @if (!isInnerKind)
                                    {
                                        <div class="col-12">
                                            <div class="d-flex align-items-center">
                                                @if (agent.IsPublished)
                                                {
                                                    <i class="bi bi-globe me-2 text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-lock me-2 text-secondary"></i>
                                                }
                                                <div class="flex-grow-1">
                                                    <small class="text-muted d-block">Status</small>
                                                    <span class="fw-medium">
                                                        @if (agent.IsPublished)
                                                        {
                                                            <span class="badge bg-success-subtle text-success">Published</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary-subtle text-secondary">Draft</span>
                                                        }
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    <div class="col-12">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-person-circle me-2 text-info"></i>
                                            <div class="flex-grow-1">
                                                <small class="text-muted d-block">Owner</small>
                                                <span class="fw-medium text-truncate d-block" title="@agent.OwnerEmail">
                                                    @agent.OwnerEmail
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-pencil-square me-2 text-warning"></i>
                                            <div class="flex-grow-1">
                                                <small class="text-muted d-block">Updated By</small>
                                                <span class="fw-medium text-truncate d-block" title="@agent.UpdatedByEmail">
                                                    @agent.UpdatedByEmail
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-clock me-2 text-success"></i>
                                            <div>
                                                <small class="text-muted d-block">Last Updated</small>
                                                <span class="fw-medium">
                                                    @agent.UpdatedAt.ToString("MMM dd, yyyy")
                                                </span>
                                                <small class="text-muted d-block">
                                                    @agent.UpdatedAt.ToString("HH:mm")
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 pt-0">
                            <div class="d-flex gap-2">
                                <a href="@($"/agents/{agent.Id}")" class="btn btn-primary flex-grow-1">
                                    <i class="bi @(isInnerKind ? "bi-gear" : "bi-arrow-right-circle") me-2"></i>
                                    @(isInnerKind ? "Manage" : "View Details")
                                </a>
                                <button class="btn btn-danger" 
                                        @onclick="() => ShowDeleteConfirmation(agent.Id, agent.Name)"
                                        disabled="@agent.IsDefault"
                                        title="@(agent.IsDefault ? "Default agent cannot be deleted" : "Delete agent")">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<DeleteAgentConfirmationModal @ref="deleteModal" OnDeleted="HandleAgentDeleted" />

@code {
    private IList<AgentListItem>? allAgents;
    private AgentKind? filterKind;
    private DeleteAgentConfirmationModal? deleteModal;

    private IList<AgentListItem> displayedAgents =>
        allAgents == null
            ? new List<AgentListItem>()
            : filterKind == null
                ? allAgents
                : allAgents.Where(a => a.AgentKind == filterKind).ToList();

    protected override async Task OnInitializedAsync()
    {
        allAgents = await AgentClient.GetListAsync();
    }

    private async Task SetFilter(AgentKind? kind)
    {
        filterKind = kind;
        allAgents = await AgentClient.GetListAsync(kind);
        StateHasChanged();
    }

    private void ShowDeleteConfirmation(Guid agentId, string agentName)
    {
        deleteModal?.ShowDeleteConfirmation(agentId, agentName);
    }

    private async Task HandleAgentDeleted()
    {
        allAgents = await AgentClient.GetListAsync(filterKind);
        StateHasChanged();
    }
}