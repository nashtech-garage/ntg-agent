# Copy to .env and adjust values for local tooling that reads environment variables
# from a file (optional; .NET Aspire uses user secrets — see README).

# SQL Server SA password (must meet SQL Server complexity rules)
SA_PASSWORD=Admin123_Strong! #gitleaks:allow

# GitHub Models token (models:read). Used by the Orchestrator.
GITHUB_TOKEN=

# MCP Google Custom Search — required to be non-empty at startup; replace for real search
GOOGLE_API_KEY=placeholder
GOOGLE_SEARCH_ENGINE_ID=placeholder

# LightRAG per-agent RAG containers
LIGHTRAG_PG_PASSWORD=
LIGHTRAG_API_KEY=
# Azure OpenAI key used for both the LightRAG LLM and embedding bindings
LIGHTRAG_EMBEDDING_API_KEY=
